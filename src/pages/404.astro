---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Página no encontrada - Dr. [Nombre]";
---

<BaseLayout title={pageTitle}>
  <Header slot="header" />

  <main class="bg-surface py-32">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-headline text-6xl text-secondary mb-6">404</h1>
      <h2 class="font-headline text-3xl text-on-background mb-6">
        Página no encontrada
      </h2>
      <p class="text-on-surface-variant mb-12 max-w-2xl mx-auto">
        Lo sentimos, la página que busca no existe o ha sido movida.
        No dude en contactarme directamente para obtener la información que necesita.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center bg-secondary hover:bg-secondary/90 text-white px-6 py-3 font-body font-medium transition-colors rounded">
          Volver al inicio
        </a>
        <a href="/#contacto" class="inline-flex items-center justify-center border border-secondary text-secondary hover:bg-secondary hover:text-white px-6 py-3 font-medium transition-colors rounded">
          Contactar directamente
        </a>
      </div>
    </div>
  </main>

  <Footer slot="footer" />
</BaseLayout>