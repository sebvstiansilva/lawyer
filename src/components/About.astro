---
const credentials = [
  "Licenciado en Ciencias Jurídicas, Universidad de Chile",
  "Especialista en Derecho del Trabajo y Previsión Social",
  "Más de 15 años de experiencia en litigación laboral",
  "Miembro del Colegio de Abogados de Chile"
];

const philosophy = "Mi enfoque se basa en la defensa incansable de los derechos laborales de mis clientes. Cada caso es único y requiere una estrategia personalizada que garantice los mejores resultados posibles.";
---

<section class="bg-surface py-20">
  <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Photo Column -->
      <div class="flex flex-col items-center lg:items-start">
        <div class="w-64 h-80 bg-surface-container-low border border-outline rounded-lg flex items-center justify-center mb-8">
          <div class="text-center text-on-surface-variant">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <p class="text-sm">Foto profesional</p>
          </div>
        </div>
        <h1 class="font-headline text-3xl text-on-background text-center lg:text-left">
          Dr. [Nombre Apellido]
        </h1>
        <p class="text-secondary mt-2 text-center lg:text-left">
          Abogado Laboral
        </p>
      </div>

      <!-- Content Column -->
      <div>
        <h2 class="font-headline text-2xl text-on-background mb-6">
          Trayectoria
        </h2>
        <div class="space-y-4 mb-12">
          {credentials.map(cred => (
            <div class="flex items-start gap-3">
              <span class="text-secondary mt-1">◆</span>
              <p class="text-on-surface-variant">{cred}</p>
            </div>
          ))}
        </div>

        <h2 class="font-headline text-2xl text-on-background mb-6">
          Filosofía de Trabajo
        </h2>
        <p class="text-on-surface-variant leading-relaxed mb-8">
          {philosophy}
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto" class="inline-flex items-center justify-center bg-secondary hover:bg-secondary/90 text-white px-6 py-3 font-body font-medium transition-colors rounded-md">
            Agenda tu consulta
          </a>
          <a href="/areas" class="inline-flex items-center justify-center border border-secondary text-secondary hover:bg-secondary hover:text-white px-6 py-3 font-medium transition-colors rounded-md">
            Ver áreas de práctica
          </a>
        </div>
      </div>
    </div>
  </div>
</section>