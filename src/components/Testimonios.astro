---
const testimonials = [
  {
    quote: "Dr. [Nombre] me representó en un caso de despido injustificado. Su profesionalismo y dedicación hicieron toda la diferencia. Recebí una indemnización justa después de un proceso largo.",
    client: "María G.",
    caseType: "Despido Injustificado"
  },
  {
    quote: "Cuando enfrenté acoso laboral, él fue la única persona que me escuchó realmente. Ganamos el caso y la empresa tuvo que pagar una compensación por daño moral. Eternamente agradecida.",
    client: "Carlos R.",
    caseType: "Acoso Laboral"
  },
  {
    quote: "Mi empresa necesitaba ayuda con negociación colectiva. Su conocimiento en derecho sindical fue invaluable. Los resultados superaron nuestras expectativas.",
    client: "Roberto V.",
    caseType: "Negociación Colectiva"
  }
];
---

<section class="bg-primary py-20">
  <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h1 class="font-headline text-4xl md:text-5xl text-white mb-6">
        Lo que dicen mis <span class="text-secondary">Clientes</span>
      </h1>
      <p class="text-white/70 text-lg max-w-3xl mx-auto">
        La satisfacción de mis clientes es mi mayor recompensa.
        Estos testimonios reflejan mi compromiso con la defensa de sus derechos.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div class="bg-surface-container-lowest border border-outline p-8 rounded-lg relative">
          <svg class="absolute top-6 left-6 w-8 h-8 text-secondary opacity-20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <div class="pt-12">
            <p class="text-on-surface-variant leading-relaxed mb-6 italic">
              "{testimonial.quote}"
            </p>
            <div class="border-t border-outline pt-4">
              <p class="text-on-background font-medium">{testimonial.client}</p>
              <p class="text-secondary text-sm">{testimonial.caseType}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="text-white/70 mb-6">
        ¿Listo para compartir su experiencia? Contácteme para comenzar.
      </p>
      <a href="/contacto" class="inline-flex items-center justify-center bg-secondary hover:bg-secondary/90 text-white px-8 py-3 font-body font-medium transition-colors rounded-md">
        Agenda su consulta
      </a>
    </div>
  </div>
</section>